# -----------------------------------------------------------------------
# AgentSentry — environment variable reference
# Copy this file to .env and fill in your values.
# For Docker: pass these via docker-compose environment blocks or a .env
# file in the docker/ directory.
# -----------------------------------------------------------------------

# Path where Claude Code agent logs are mounted (read-only)
# This is the .claude directory from the machine running the AI agent.
AGENT_DATA_DIR=/data/agent-logs

# Directory for AgentScout's high-water mark state file
STATE_DIR=/var/lib/agentsentry/scout

# Watchtower API base URL (used by AgentScout and the dashboard build)
WATCHTOWER_URL=http://localhost:8000

# PostgreSQL connection string (asyncpg dialect)
DATABASE_URL=postgresql+asyncpg://agentsentry:changeme@localhost:5432/agentsentry

# Dashboard API URL (browser-visible if any client components call the API)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Disable Next.js telemetry (keep this set to 1)
NEXT_TELEMETRY_DISABLED=1

# Log levels
LOG_LEVEL=INFO
