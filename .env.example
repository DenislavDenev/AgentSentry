# -----------------------------------------------------------------------
# AgentSentry — environment variable reference
# Copy this file to .env and fill in your values.
# All variables are optional; defaults are shown.
# -----------------------------------------------------------------------

# Path to the mounted agent log directory (Claude Code .claude folder).
AGENT_DATA_DIR=/data/agent-logs

# SQLite database path.
DATABASE_URL=sqlite+aiosqlite:////var/lib/agentsentry/agentsentry.db

# Directory for scout high-water mark state file.
STATE_DIR=/var/lib/agentsentry/scout

# Path to the built Vite dist/ folder (set by the install scripts).
DASHBOARD_DIR=/opt/agentsentry/packages/dashboard-vite/dist

# Listen address and port.
HOST=0.0.0.0
PORT=8000

# Log level.
LOG_LEVEL=INFO
